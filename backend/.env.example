# Copy to .env and adjust. Used by ingest_service.py and train_if.py

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smarttag
POSTGRES_USER=smarttag
POSTGRES_PASSWORD=smarttag_local_only

MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# Optional: path to joblib after train_if.py (ingest loads if set)
MODEL_PATH=artifacts/model_v0.joblib

# RMS fallback threshold (mg) — tune after watching normal stream
RMS_THRESH=25.0

# Demo UI / deviation %: map RMS (mg) linearly to 0..100 between these bounds; IF outlier bumps to at least floor
RMS_DEV_LOW=5
RMS_DEV_HIGH=85
IF_OUTLIER_PCT_FLOOR=90

PIPELINE_VERSION=v0
