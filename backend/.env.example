# Copy to .env and adjust. Used by ingest_service.py and train_if.py

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smarttag
POSTGRES_USER=smarttag
POSTGRES_PASSWORD=smarttag_local_only

MQTT_HOST=127.0.0.1
MQTT_PORT=1883

DEVICE_ID=esp32dev001
AUTO_START_INGEST=1

# Optional: path to joblib after train_if.py (ingest loads if set)
MODEL_PATH=artifacts/model_v0.joblib

# RMS fallback threshold (mg) — tune after watching normal stream
RMS_THRESH=25.0

# Demo UI / deviation %: model-based severity. 0% for positive IF score, 100% at score <= -threshold.
IF_SCORE_BAD_THRESHOLD=0.15

PIPELINE_VERSION=v0

# Live UI training session: auto-stop and train after this many windows.
MIN_TRAIN_WINDOWS=1500
